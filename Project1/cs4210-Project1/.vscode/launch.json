{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug matrix with gdb",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/gtthreads/bin/matrix",
            "args": [],                              // add program args here
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/gtthreads",
            "environment": [],
            "externalConsole": false,               // true = open separate terminal
            "MIMode": "gdb",                        // tell VS Code to use gdb
            "miDebuggerPath": "/usr/bin/gdb",       // path to gdb (check with `which gdb`)
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
